# ── AssemblyAI ─────────────────────────────────────────────────────────────
# Required. Get a free key at https://www.assemblyai.com/
ASSEMBLYAI_API_KEY=your_assemblyai_key_here

# ── AI Analysis Provider ────────────────────────────────────────────────────
# Choose "anthropic" (Claude) or "openai" (GPT-4o).
# You only need to fill in the key for the provider you choose.
AI_PROVIDER=anthropic

# ── Anthropic Claude ────────────────────────────────────────────────────────
# Get a key at https://platform.claude.com/settings/api-keys
ANTHROPIC_API_KEY=your_anthropic_key_here

# ── OpenAI GPT-4o ───────────────────────────────────────────────────────────
# Get a key at https://platform.openai.com/api-keys
# OPENAI_API_KEY=your_openai_key_here
